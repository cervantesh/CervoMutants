 // processMutationFile parses one source file, applies all mutators, and enqueues jobs.
 // Returns the mutation count for this file and an exit code.
+func diffFiles(originalPath, mutationPath string) ([]byte, int, error) {
+	orig, err := os.ReadFile(originalPath)
+	if err != nil {
+		return nil, 2, err
+	}
+	mut, err := os.ReadFile(mutationPath)
+	if err != nil {
+		return nil, 2, err
+	}
+	if bytes.Equal(orig, mut) {
+		return nil, 0, nil
+	}
+	origLines := strings.Split(string(orig), "\n")
+	mutLines := strings.Split(string(mut), "\n")
+	var b bytes.Buffer
+	fmt.Fprintf(&b, "--- Original\n")
+	fmt.Fprintf(&b, "+++ New\n")
+	fmt.Fprintf(&b, "@@ -1,%d +1,%d @@\n", len(origLines), len(mutLines))
+	for _, line := range origLines {
+		if line != "" {
+			fmt.Fprintf(&b, "-%s\n", line)
+		}
+	}
+	for _, line := range mutLines {
+		if line != "" {
+			fmt.Fprintf(&b, "+%s\n", line)
+		}
+	}
+	return b.Bytes(), 1, nil
+}
+func tempMutationFilePath(tmpDir, moduleRoot, file string) (string, error) {
+	absFile, err := filepath.Abs(file)
+	if err != nil {
+		return "", err
+	}
+	absRoot, err := filepath.Abs(moduleRoot)
+	if err != nil {
+		return "", err
+	}
+	rel, err := filepath.Rel(absRoot, absFile)
+	if err != nil || rel == "." || rel == ".." || strings.HasPrefix(rel, ".."+string(os.PathSeparator)) || filepath.IsAbs(rel) {
+		rel = filepath.Base(absFile)
+	}
+	return filepath.Join(tmpDir, "mutations", rel), nil
+}

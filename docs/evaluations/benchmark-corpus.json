      "target": "./doc",
      "size": "small",
      "resource_class": "low",
      "policy": "comparison-safe",
      "max_mutants": 50,
      "workers": 2,
      "clone_timeout_seconds": 180,
      "baseline_timeout_seconds": 60,
      "dry_run_timeout_seconds": 60,
      "mutation_timeout_seconds": 180,
      "thresholds": {
        "max_baseline_seconds": 20,
        "max_dry_run_seconds": 45,
        "max_mutation_seconds": 180,
        "max_peak_memory_mb": 512,
        "min_mutants_per_second": 0.5,
        "min_executed_mutants": 25
      },
      "notes": "Small CLI target with a historically repeatable comparison-safe lane."
    },
    {
